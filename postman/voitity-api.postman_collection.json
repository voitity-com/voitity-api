    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Wompi Checkout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json.data && json.data.payment_order) {",
                  "  pm.environment.set(\"payment_order_id\", json.data.payment_order.id);",
                  "  pm.environment.set(\"payment_reference\", json.data.payment_order.reference);",
                  "  if (json.data.payment_order.amounts) {",
                  "    pm.environment.set(\"wompi_event_amount_in_cents\", String(json.data.payment_order.amounts.amount_in_cents));",
                  "  }",
                  "  pm.environment.unset(\"wompi_event_id\");",
                  "  pm.environment.unset(\"wompi_transaction_id\");",
                  "  pm.environment.unset(\"wompi_event_checksum\");",
                  "}",
                  "if (json.data && json.data.checkout) {",
                  "  pm.environment.set(\"wompi_checkout_url\", json.data.checkout.checkout_url);",
                  "}",
                  "pm.environment.set(\"wompi_event_status\", pm.environment.get(\"wompi_event_status\") || \"APPROVED\");"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan\": \"starter\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/payments/wompi/checkout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payments",
                "wompi",
                "checkout"
              ]
            },
            "description": "Creates a pending local payment order and returns Wompi Web Checkout URL plus Widget config. Requires token ability: payments:create. Open wompi_checkout_url to pay in Sandbox."
          },
          "response": []
        },
        {
          "name": "Get Payment Order",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/payments/{{payment_order_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
