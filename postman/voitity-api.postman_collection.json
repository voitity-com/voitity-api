              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json.data && Array.isArray(json.data.chats) && json.data.chats.length) {",
                  "  pm.environment.set('chat_id', json.data.chats[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/profile/chats?profile_id={{profile_id}}&page={{chat_page}}",
              "host": [
