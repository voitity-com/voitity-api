                "{{base_url}}"
              ],
              "path": [
                "api",
                "profile"
              ]
            },
            "description": "Lists profiles that belong to the authenticated user. Requires token ability: profile:read."
          },
          "response": []
        },
        {
          "name": "Create Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json.data && json.data.id) {",
                  "  pm.environment.set('profile_id', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{profile_name}}\",\n  \"alias\": \"{{profile_alias}}\",\n  \"description\": \"{{profile_description}}\",\n  \"genre\": \"{{profile_genre}}\",\n  \"personality\": \"{{profile_personality}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/profile",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "profile"
              ]
            },
            "description": "Creates a profile and stores profile_id from data.id. New profiles default to status draft."
          },
          "response": []
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/profile/{{profile_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "profile",
                "{{profile_id}}"
              ]
            },
            "description": "Retrieves the profile identified by profile_id."
          },
          "response": []
        },
        {
