        {
          "name": "Upload Voice Sample",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json.data && json.data.id) {",
                  "  pm.environment.set('voice_sample_id', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "{{voice_sample_file_path}}"
                },
                {
                  "key": "language_code",
                  "value": "{{language_code}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/voice/{{voice_id}}/sample",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "voice",
                "{{voice_id}}",
                "sample"
              ]
            },
            "description": "Uploads an audio file for a voice. Set voice_sample_file_path in the environment to a local mp3 or wav path."
          },
          "response": []
        },
        {
          "name": "Process Voice Sample",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/voice/{{voice_id}}/sample/{{voice_sample_id}}/process",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "voice",
                "{{voice_id}}",
                "sample",
                "{{voice_sample_id}}",
                "process"
              ]
            },
            "description": "Starts processing a voice sample. This can call external voice provider code depending on configuration."
          },
          "response": []
        },
        {
          "name": "Test Voice",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const voiceTestText = pm.environment.get('voice_test_text') || '';",
                  "pm.variables.set('voice_test_text_json', JSON.stringify(voiceTestText));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"profile_id\": \"{{profile_id}}\",\n  \"text\": {{voice_test_text_json}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/voice/test",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "voice",
                "test"
              ]
            },
            "description": "Generates test audio using the active voice for the selected profile. Requires voice:use ability."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Avatar",
      "item": [
        {
          "name": "Generate Avatar",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json.data && json.data.id) {",
                  "  pm.environment.set('aiimage_id', json.data.id);",
                  "}",
                  "if (json.data && json.data.source_id) {",
                  "  pm.environment.set('aiimage_source_id', json.data.source_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "profile_id",
                  "value": "{{profile_id}}",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": "{{avatar_image_file_path}}"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/avatar/generate",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "avatar",
                "generate"
              ]
            },
            "description": "Uploads a source image and starts avatar generation for the selected profile. Requires avatar:write. Non-admin users can only generate avatars for their own profiles; admins can generate for any profile. Set avatar_image_file_path to a local jpg, png, or webp image."
          },
          "response": []
        },
        {
          "name": "Get Avatar",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/avatar/{{profile_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "avatar",
                "{{profile_id}}"
              ]
            },
            "description": "Gets the active avatar for profile_id. Requires avatar:read."
          },
          "response": []
        }
      ]
    }
  ]
}
