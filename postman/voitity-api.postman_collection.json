    {
      "name": "Messages",
      "item": [
        {
          "name": "List Chats",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json.data && Array.isArray(json.data.chats) && json.data.chats.length) {",
                  "  pm.environment.set('chat_id', json.data.chats[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/profile/chats?profile_id={{profile_id}}&page={{chat_page}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "profile",
                "chats"
              ],
              "query": [
                {
                  "key": "profile_id",
                  "value": "{{profile_id}}"
                },
                {
                  "key": "page",
                  "value": "{{chat_page}}"
                }
              ]
            },
            "description": "Lists chats for profile_id, ordered by last update descending and paginated by 20. Includes api/openai message counts and last_message_at. Requires chat:read. Admin users can read any profile; non-admin users can only read their own profiles."
          },
          "response": []
        },
        {
          "name": "List Chat Messages",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json.data && Array.isArray(json.data.messages) && json.data.messages.length) {",
                  "  pm.environment.set('message_id', json.data.messages[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/profile/chats/messages?profile_id={{profile_id}}&chat_id={{chat_id}}&page={{message_page}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "profile",
                "chats",
                "messages"
              ],
              "query": [
                {
                  "key": "profile_id",
                  "value": "{{profile_id}}"
                },
                {
                  "key": "chat_id",
                  "value": "{{chat_id}}"
                },
                {
                  "key": "page",
                  "value": "{{message_page}}"
                }
              ]
            },
            "description": "Lists messages for chat_id within profile_id, ordered chronologically and paginated by 20. Requires chat:read. Admin users can read any profile; non-admin users can only read their own profiles. The chat must belong to the profile."
          },
          "response": []
        },
        {
          "name": "Send Message - New Chat",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json.data) {",
                  "  if (json.data.chat_id) pm.environment.set('chat_id', json.data.chat_id);",
                  "  if (json.data.message_id) pm.environment.set('message_id', json.data.message_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"{{message_text}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/profile/{{profile_id}}/messages",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "profile",
                "{{profile_id}}",
                "messages"
              ]
            },
            "description": "Creates a new chat for the profile when chat_id is omitted."
          },
          "response": []
        },
        {
          "name": "Send Message - Existing Chat",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json.data) {",
                  "  if (json.data.chat_id) pm.environment.set('chat_id', json.data.chat_id);",
                  "  if (json.data.message_id) pm.environment.set('message_id', json.data.message_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"{{message_text}}\",\n  \"chat_id\": \"{{chat_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/profile/{{profile_id}}/messages",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "profile",
                "{{profile_id}}",
                "messages"
              ]
            },
            "description": "Sends a message to an existing chat. Run 'Send Message - New Chat' first to populate chat_id."
          },
          "response": []
        }
      ]
    },
